# Copy to .env and fill in required values.

# PostgreSQL
POSTGRES_DB=ginbar
POSTGRES_USER=ginbar
POSTGRES_PASSWORD=changeme

# Fiber session secret — generate with: openssl rand -hex 32
SESSION_SECRET=changeme

# Port nginx listens on (default 80)
HTTP_PORT=80

# Initial admin user password (only applied on first-ever startup; changing
# this after the admin user exists has no effect — use the password-update API)
ADMIN_PASSWORD=changeme
